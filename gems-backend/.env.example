# Server
PORT=3000
NODE_ENV=development

# Public-facing base URL of this server (used to build asset URLs in responses).
# In production set this to your deployed API domain, e.g. https://api.example.com
BASE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gems

# JWT
JWT_SECRET=change_me

# CORS — comma-separated frontend origins (leave unset to allow all in dev)
# CORS_ORIGIN=https://app.example.com

# File storage — set STORAGE_TYPE=s3 to use S3-compatible storage instead of local disk
# STORAGE_TYPE=s3
# S3_REGION=us-east-1
# S3_BUCKET=gems-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # optional: MinIO or other S3-compatible endpoint
